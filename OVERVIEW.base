views:
  - type: table
    name: Table
    filters:
      and:
        - and:
            - file.ext != "base"
            - '!file.name.startsWith("template-")'
    groupBy:
      property: module_type
      direction: ASC
    order:
      - module_type
      - file.name
      - file.tags
      - status
    sort:
      - property: module_type
        direction: ASC
    columnSize:
      file.tags: 416
